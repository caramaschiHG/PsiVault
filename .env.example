# PsiVault — Variáveis de Ambiente de Produção
# Configure estas variáveis no painel da Vercel: Settings > Environment Variables
#
# ATENÇÃO: Nunca commitar o arquivo .env com valores reais.
# Este arquivo é apenas um template — copie para .env.local para desenvolvimento.

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard > Settings > API > Project API Keys > anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard > Settings > API > Project API Keys > service_role (secret)
# NUNCA expor no frontend — apenas server-side
SUPABASE_SERVICE_ROLE_KEY=

# ── Banco de Dados (Prisma) ────────────────────────────────────────────────────
# Supabase Dashboard > Settings > Database > Connection string > Transaction pooler (porta 6543)
# Usado para queries em runtime (via Supavisor connection pooling)
# Adicionar ?pgbouncer=true ao final da string
DATABASE_URL=

# Supabase Dashboard > Settings > Database > Connection string > Direct connection (porta 5432)
# Usado por prisma migrate deploy (requer conexão direta, não pooler)
DIRECT_URL=

# ── Site ───────────────────────────────────────────────────────────────────────
# URL pública do site — usado em links de e-mail (ex: reset de senha)
# Em produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=
