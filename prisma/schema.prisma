generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MfaMethod {
  TOTP
}

enum ServiceMode {
  IN_PERSON
  ONLINE
  HYBRID
}

model Account {
  id            String         @id @default(uuid())
  email         String         @unique
  displayName   String?        @map("display_name")
  mfaRequired   Boolean        @default(true) @map("mfa_required")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workspace     Workspace?
  mfaEnrollment MfaEnrollment?

  @@map("accounts")
}

model Workspace {
  id              String           @id @default(uuid())
  ownerAccountId  String           @unique @map("owner_account_id")
  slug            String           @unique
  displayName     String           @map("display_name")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  ownerAccount    Account          @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile?
  patients        Patient[]
  appointments    Appointment[]

  @@unique([id, ownerAccountId])
  @@map("workspaces")
}

model MfaEnrollment {
  id                String    @id @default(uuid())
  accountId         String    @unique @map("account_id")
  method            MfaMethod @default(TOTP)
  secretCiphertext  String    @map("secret_ciphertext")
  recoveryCodesHash String[]  @map("recovery_codes_hash")
  verifiedAt        DateTime? @map("verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("mfa_enrollments")
}

model PracticeProfile {
  id                                String          @id @default(uuid())
  workspaceId                       String          @unique @map("workspace_id")
  fullName                          String?         @map("full_name")
  crp                               String?
  contactEmail                      String?         @map("contact_email")
  contactPhone                      String?         @map("contact_phone")
  defaultAppointmentDurationMinutes Int?            @map("default_appointment_duration_minutes")
  defaultSessionPriceInCents        Int?            @map("default_session_price_in_cents")
  serviceModes                      ServiceMode[]   @map("service_modes")
  createdAt                         DateTime        @default(now()) @map("created_at")
  updatedAt                         DateTime        @updatedAt @map("updated_at")
  workspace                         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signatureAsset                    SignatureAsset?

  @@map("practice_profiles")
}

model SignatureAsset {
  id         String          @id @default(uuid())
  profileId  String          @unique @map("profile_id")
  storageKey String          @map("storage_key")
  fileName   String          @map("file_name")
  mimeType   String          @map("mime_type")
  fileSize   Int             @map("file_size")
  uploadedAt DateTime        @map("uploaded_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  profile    PracticeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("signature_assets")
}

enum AppointmentCareMode {
  IN_PERSON
  ONLINE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

model Appointment {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  patientId   String @map("patient_id")

  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  durationMinutes Int      @map("duration_minutes")

  careMode AppointmentCareMode @map("care_mode")
  status   AppointmentStatus   @default(SCHEDULED)

  // Recurrence linkage (null for standalone appointments)
  seriesId    String? @map("series_id")
  seriesIndex Int?    @map("series_index")

  // Reschedule linkage — preserves visible history
  rescheduledFromId String? @map("rescheduled_from_id")

  // Lifecycle timestamps
  canceledAt          DateTime? @map("canceled_at")
  canceledByAccountId String?   @map("canceled_by_account_id")
  confirmedAt         DateTime? @map("confirmed_at")
  completedAt         DateTime? @map("completed_at")
  noShowAt            DateTime? @map("no_show_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startsAt])
  @@index([workspaceId, patientId])
  @@index([seriesId])
  @@map("appointments")
}

model Patient {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")

  // Core identity
  fullName   String  @map("full_name")
  socialName String? @map("social_name")

  // Contact (optional)
  email String?
  phone String?

  // Guardian (optional — minor patients or caregiver contexts)
  guardianName  String? @map("guardian_name")
  guardianPhone String? @map("guardian_phone")

  // Emergency contact (optional)
  emergencyContactName  String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")

  // Important observations — must not appear in list/agenda surfaces
  importantObservations String? @map("important_observations")

  // Soft archive (deleted_at)
  deletedAt          DateTime? @map("deleted_at")
  deletedByAccountId String?   @map("deleted_by_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([workspaceId, deletedAt])
  @@map("patients")
}
