generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MfaMethod {
  TOTP
}

enum ServiceMode {
  IN_PERSON
  ONLINE
  HYBRID
}

model Account {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  displayName        String?
  emailVerifiedAt    DateTime?
  mfaRequired        Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workspace          Workspace?
  sessions           Session[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  mfaEnrollment      MfaEnrollment?
}

model Workspace {
  id             String   @id @default(cuid())
  ownerAccountId String   @unique
  slug           String   @unique
  displayName    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ownerAccount   Account  @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  sessions       Session[]
  practiceProfile PracticeProfile?
  patients        Patient[]
  appointments    Appointment[]

  @@unique([id, ownerAccountId])
}

model Session {
  id            String    @id @default(cuid())
  accountId     String
  workspaceId   String
  sessionToken  String    @unique
  expiresAt     DateTime
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([accountId, revokedAt])
  @@index([workspaceId, revokedAt])
}

model VerificationToken {
  id         String    @id @default(cuid())
  accountId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, consumedAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  accountId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, consumedAt])
}

model MfaEnrollment {
  id                 String    @id @default(cuid())
  accountId          String    @unique
  method             MfaMethod @default(TOTP)
  secretCiphertext   String
  recoveryCodesHash  String[]
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  account            Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PracticeProfile {
  id                                String         @id @default(cuid())
  workspaceId                       String         @unique
  fullName                          String?
  crp                               String?
  contactEmail                      String?
  contactPhone                      String?
  defaultAppointmentDurationMinutes Int?
  defaultSessionPriceInCents        Int?
  serviceModes                      ServiceMode[]
  createdAt                         DateTime       @default(now())
  updatedAt                         DateTime       @updatedAt
  workspace                         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signatureAsset                    SignatureAsset?
}

model SignatureAsset {
  id         String          @id @default(cuid())
  profileId  String          @unique
  storageKey String
  fileName   String
  mimeType   String
  fileSize   Int
  uploadedAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  profile    PracticeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum AppointmentCareMode {
  IN_PERSON
  ONLINE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

model Appointment {
  id          String    @id @default(cuid())
  workspaceId String
  patientId   String

  startsAt        DateTime
  endsAt          DateTime
  durationMinutes Int

  careMode AppointmentCareMode
  status   AppointmentStatus   @default(SCHEDULED)

  // Recurrence linkage (null for standalone appointments)
  seriesId    String?
  seriesIndex Int?

  // Reschedule linkage — preserves visible history
  rescheduledFromId String?

  // Lifecycle timestamps
  canceledAt           DateTime?
  canceledByAccountId  String?
  confirmedAt          DateTime?
  completedAt          DateTime?
  noShowAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startsAt])
  @@index([workspaceId, patientId])
  @@index([seriesId])
}

model Patient {
  id          String    @id @default(cuid())
  workspaceId String

  // Core identity
  fullName   String
  socialName String?

  // Contact (optional)
  email String?
  phone String?

  // Guardian (optional — minor patients or caregiver contexts)
  guardianName  String?
  guardianPhone String?

  // Emergency contact (optional)
  emergencyContactName  String?
  emergencyContactPhone String?

  // Important observations — must not appear in list/agenda surfaces
  importantObservations String?

  // Soft archive
  archivedAt           DateTime?
  archivedByAccountId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([workspaceId, archivedAt])
}
