generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MfaMethod {
  TOTP
}

enum ServiceMode {
  IN_PERSON
  ONLINE
  HYBRID
}

model Account {
  id            String         @id @default(uuid())
  email         String         @unique
  displayName   String?        @map("display_name")
  mfaRequired   Boolean        @default(true) @map("mfa_required")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workspace     Workspace?
  mfaEnrollment MfaEnrollment?

  @@map("accounts")
}

model Workspace {
  id              String           @id @default(uuid())
  ownerAccountId  String           @unique @map("owner_account_id")
  slug            String           @unique
  displayName     String           @map("display_name")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  ownerAccount    Account          @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile?
  patients        Patient[]
  appointments    Appointment[]
  clinicalNotes   ClinicalNote[]
  documents       PracticeDocument[]
  sessionCharges  SessionCharge[]
  auditEvents     AuditEvent[]
  reminders       Reminder[]
  smtpConfig      WorkspaceSmtpConfig?
  notificationJobs NotificationJob[]

  @@unique([id, ownerAccountId])
  @@map("workspaces")
}

model MfaEnrollment {
  id                String    @id @default(uuid())
  accountId         String    @unique @map("account_id")
  method            MfaMethod @default(TOTP)
  secretCiphertext  String    @map("secret_ciphertext")
  recoveryCodesHash String[]  @map("recovery_codes_hash")
  verifiedAt        DateTime? @map("verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("mfa_enrollments")
}

model PracticeProfile {
  id                                String          @id @default(uuid())
  workspaceId                       String          @unique @map("workspace_id")
  fullName                          String?         @map("full_name")
  crp                               String?
  contactEmail                      String?         @map("contact_email")
  contactPhone                      String?         @map("contact_phone")
  defaultAppointmentDurationMinutes Int?            @map("default_appointment_duration_minutes")
  defaultSessionPriceInCents        Int?            @map("default_session_price_in_cents")
  serviceModes                      ServiceMode[]   @map("service_modes")
  createdAt                         DateTime        @default(now()) @map("created_at")
  updatedAt                         DateTime        @updatedAt @map("updated_at")
  workspace                         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signatureAsset                    SignatureAsset?

  @@map("practice_profiles")
}

model SignatureAsset {
  id         String          @id @default(uuid())
  profileId  String          @unique @map("profile_id")
  storageKey String          @map("storage_key")
  fileName   String          @map("file_name")
  mimeType   String          @map("mime_type")
  fileSize   Int             @map("file_size")
  uploadedAt DateTime        @map("uploaded_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  profile    PracticeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("signature_assets")
}

enum AppointmentCareMode {
  IN_PERSON
  ONLINE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

model Appointment {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  patientId   String @map("patient_id")

  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  durationMinutes Int      @map("duration_minutes")

  careMode AppointmentCareMode @map("care_mode")
  status   AppointmentStatus   @default(SCHEDULED)

  // Recurrence linkage (null for standalone appointments)
  seriesId    String? @map("series_id")
  seriesIndex Int?    @map("series_index")

  // Reschedule linkage — preserves visible history
  rescheduledFromId String? @map("rescheduled_from_id")

  // Lifecycle timestamps
  canceledAt          DateTime? @map("canceled_at")
  canceledByAccountId String?   @map("canceled_by_account_id")
  confirmedAt         DateTime? @map("confirmed_at")
  completedAt         DateTime? @map("completed_at")
  noShowAt            DateTime? @map("no_show_at")

  // Finance — deferred from Phase 2 [02-04], hydrated in Phase 5
  priceInCents Int? @map("price_in_cents")

  // Online care — ONLN-01, ONLN-03
  meetingLink     String? @map("meeting_link")
  remoteIssueNote String? @map("remote_issue_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalNote     ClinicalNote?
  sessionCharge    SessionCharge?
  notificationJobs NotificationJob[]

  @@index([workspaceId, startsAt])
  @@index([workspaceId, patientId])
  @@index([seriesId])
  @@map("appointments")
}

model Patient {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")

  // Core identity
  fullName   String  @map("full_name")
  socialName String? @map("social_name")

  // Contact (optional)
  email String?
  phone String?

  // Guardian (optional — minor patients or caregiver contexts)
  guardianName  String? @map("guardian_name")
  guardianPhone String? @map("guardian_phone")

  // Emergency contact (optional)
  emergencyContactName  String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")

  // Important observations — must not appear in list/agenda surfaces
  importantObservations String? @map("important_observations")

  // Soft archive (deleted_at)
  deletedAt          DateTime? @map("deleted_at")
  deletedByAccountId String?   @map("deleted_by_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  clinicalNotes    ClinicalNote[]
  documents        PracticeDocument[]
  sessionCharges   SessionCharge[]
  reminders        Reminder[]
  notificationJobs NotificationJob[]

  @@index([workspaceId, deletedAt])
  @@map("patients")
}

model ClinicalNote {
  id            String @id @default(uuid())
  workspaceId   String @map("workspace_id")
  patientId     String @map("patient_id")
  appointmentId String @unique @map("appointment_id")

  freeText          String  @map("free_text")
  demand            String?
  observedMood      String? @map("observed_mood")
  themes            String?
  clinicalEvolution String? @map("clinical_evolution")
  nextSteps         String? @map("next_steps")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  editedAt  DateTime? @map("edited_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, patientId])
  @@map("clinical_notes")
}

model PracticeDocument {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  patientId   String @map("patient_id")

  type    String // DocumentType stored as TEXT — cast in mapToDomain()
  content String // PostgreSQL TEXT, no size limit

  createdByAccountId String @map("created_by_account_id")
  createdByName      String @map("created_by_name")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  editedAt  DateTime? @map("edited_at")

  archivedAt          DateTime? @map("archived_at")
  archivedByAccountId String?   @map("archived_by_account_id")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([workspaceId, patientId])
  @@map("practice_documents")
}

model SessionCharge {
  id            String @id @default(uuid())
  workspaceId   String @map("workspace_id")
  patientId     String @map("patient_id")
  appointmentId String @unique @map("appointment_id")

  status        String    // ChargeStatus: "pendente" | "pago" | "atrasado"
  amountInCents Int?      @map("amount_in_cents")
  paymentMethod String?   @map("payment_method")
  paidAt        DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, patientId])
  @@map("session_charges")
}

model AuditEvent {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")

  type       String   // TEXT — no enum; new event types without migration
  occurredAt DateTime @default(now()) @map("occurred_at")

  actorAccountId   String  @map("actor_account_id")
  actorSessionId   String? @map("actor_session_id")
  actorDisplayName String? @map("actor_display_name")

  subjectKind  String? @map("subject_kind")
  subjectId    String? @map("subject_id")
  subjectLabel String? @map("subject_label")

  summary  String
  metadata Json   @default("{}")

  // NO updatedAt — append-only, immutable audit trail

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@map("audit_events")
}

model Reminder {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  patientId   String? @map("patient_id")

  title String

  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")

  linkType String? @map("link_type")
  linkId   String? @map("link_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patient   Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([workspaceId, completedAt])
  @@index([workspaceId, linkType, linkId])
  @@map("reminders")
}

model WorkspaceSmtpConfig {
  id                  String    @id @default(uuid())
  workspaceId         String    @unique @map("workspace_id")
  host                String
  port                Int       @default(587)
  secure              Boolean   @default(false)
  username            String
  passwordCiphertext  String    @map("password_ciphertext")
  fromName            String    @map("from_name")
  fromEmail           String    @map("from_email")
  sendReminder24h     Boolean   @default(true) @map("send_reminder_24h")
  sendReminder1h      Boolean   @default(true) @map("send_reminder_1h")
  sendConfirmation    Boolean   @default(true) @map("send_confirmation")
  sendCancellation    Boolean   @default(true) @map("send_cancellation")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_smtp_configs")
}

model NotificationJob {
  id             String    @id @default(uuid())
  workspaceId    String    @map("workspace_id")
  appointmentId  String    @map("appointment_id")
  patientId      String    @map("patient_id")
  recipientEmail String    @map("recipient_email")
  type           String    // REMINDER_24H | REMINDER_1H | CONFIRMATION | CANCELLATION
  status         String    @default("PENDING") // PENDING | SENT | FAILED | CANCELED
  scheduledFor   DateTime  @map("scheduled_for")
  sentAt         DateTime? @map("sent_at")
  failedAt       DateTime? @map("failed_at")
  errorNote      String?   @map("error_note")
  idempotencyKey String    @unique @map("idempotency_key")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, scheduledFor])
  @@index([appointmentId, type])
  @@map("notification_jobs")
}
