{
  "name": "psivault-video",
  "version": "1.0.0",
  "description": "PsiVault — flagship product video (25s)",
  "private": true,
  "scripts": {
    "preview": "remotion preview src/index.ts",
    "render": "remotion render src/index.ts PsiVaultVideo out/psivault-25s.mp4 --gl=angle",
    "still": "remotion still src/index.ts PsiVaultVideo --frame=0 out/thumbnail.png"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
